{
  "name": "pi-to-pi",
  "version": "0.1.0",
  "description": "Pi package with Pi-to-Pi communication plus reusable agent personas and pi-pi expert orchestrator",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-coding-agent",
    "agent-communication",
    "coms",
    "sse",
    "agents",
    "orchestration"
  ],
  "pi": {
    "extensions": [
      "./extensions/coms.ts",
      "./extensions/coms-net.ts",
      "./extensions/pi-pi.ts",
      "./extensions/agent-chain.ts",
      "./extensions/cross-agent.ts",
      "./extensions/agent-team.ts",
      "./extensions/cross-team.ts",
      "./extensions/tilldone.ts"
    ],
    "prompts": [
      "./agents/scout.md",
      "./agents/planner.md",
      "./agents/builder.md",
      "./agents/reviewer.md",
      "./agents/documenter.md",
      "./agents/browser.md",
      "./agents/plan-reviewer.md",
      "./agents/red-team.md",
      "./agents/blue-team.md"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "files": [
    "extensions/coms.ts",
    "extensions/coms-net.ts",
    "extensions/pi-pi.ts",
    "extensions/agent-chain.ts",
    "extensions/cross-agent.ts",
    "extensions/agent-team.ts",
    "extensions/cross-team.ts",
    "extensions/tilldone.ts",
    "agents/scout.md",
    "agents/planner.md",
    "agents/builder.md",
    "agents/reviewer.md",
    "agents/documenter.md",
    "agents/browser.md",
    "agents/plan-reviewer.md",
    "agents/red-team.md",
    "agents/blue-team.md",
    "agents/agent-chain.yaml",
    "agents/teams.yaml",
    "agents/pi-pi/*.md",
    "scripts/coms-net-server.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "check:load": "PI_OFFLINE=1 pi -e ./extensions/coms.ts -e ./extensions/coms-net.ts -e ./extensions/pi-pi.ts -e ./extensions/agent-chain.ts -e ./extensions/cross-agent.ts -e ./extensions/agent-team.ts -e ./extensions/cross-team.ts -e ./extensions/tilldone.ts --help",
    "check:pack": "npm pack --dry-run"
  }
}
